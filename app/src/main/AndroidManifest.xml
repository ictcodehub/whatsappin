<?xml version="1.0" encoding="utf-8"?>
<!--
=====================================================================
File: AndroidManifest.xml
Tujuan: Mendeklarasikan komponen aplikasi, izin, dan meta-data sistem Android
Dipakai oleh: Sistem Operasi Android & Google Play
Dependensi Utama: SDK Android, MainActivity
Daftar Fungsi: Konfigurasi MainActivity, Izin Internet, Izin Baca Kontak
Side Effect: Menentukan entry point peluncuran aplikasi dan izin runtime
=====================================================================
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Izin untuk fungsionalitas eksternal -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.WADirect"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.WADirect">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
